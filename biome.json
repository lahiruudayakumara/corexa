{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignore": [
      "dist/**",
      "out/**",
      "apps/desktop/out/**",
      "build/**",
      ".turbo/**",
      "coverage/**",
      "memory/qdrant/snapshots/**"
    ]
  }
}
